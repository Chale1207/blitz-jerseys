## Copy this file to local.properties and fill in the values.
## local.properties is gitignored — never commit the real file.

## Android SDK location
sdk.dir=/path/to/android_sdk

## Signing keystore (generated by: KEYSTORE_PASSWORD=... node scripts/twa-keygen.js)
storeFile=../blitz-jerseys.keystore
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=blitzjerseys
keyPassword=YOUR_KEYSTORE_PASSWORD
